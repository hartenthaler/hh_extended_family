msgstr "Samenvatting voor de getoonde uitgebreide familie"

#, php-format
msgid "The extended family has only %1$s as a member."
msgid_plural "The extended family of %1$s has %2$d members (including %1$s)."
msgstr[0] "De uitgebreide familie heeft alleen %1$s als lid."
