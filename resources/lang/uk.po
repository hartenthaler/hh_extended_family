msgid "yes, always at standard location"
msgstr "так, завжди на звичайному місці"

msgid "no, but collect messages about empty blocks at the end"
msgstr "ні, але збирати повідомлення про порожні блоки в кінці"

msgid "never"
msgstr "ніколи"

msgid "Show options to filter the results?"
