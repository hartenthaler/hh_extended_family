#, php-format
msgid "The preferences for the module “%s” have been updated."
msgstr "Predvoľby modulu \"%s\" boli uložené."

#: ExtendedFamilyTabModule.php:596
msgid ""
"The custom module “huhwt-cce” is not available. The button “copy to "
"clippings cart” will use the internal Extended Family action."
msgstr ""
"Užívateľský modul “huhwt-cce” nie je prístupný. Tlačidlo \"kopírovať do "
"schránky výstrižkov\" použije internú akciu modulu širšia rodina."

