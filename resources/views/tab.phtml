<?php

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Individual;

/**
 * @var Individual  $individual             the primary individual (proband)
 * @var string      $module                 module namespace used for partial views
 * @var object      $extfam_obj             contains all the information which has to be shown
 * @var string      $extended_family_css    used in JavaScript code as a link to the CSS file
 * @var string      $clippings_cart_action  selected action for the clippings-cart button
 */

    $tree_name = $individual->tree()->name();
    $summaryName = '<span class="hh-extended-family-summary-name">' . $extfam_obj->proband->niceName->name . '</span>';
?>
 
<div class="wt-tab-hh-extended-family py-4">
    <?= view($module . '::partials/filter-controls', [
        'extfam_obj' => $extfam_obj,
    ]) ?>
    <?php foreach ($extfam_obj->filters as $filterOption => $filterObj) : ?>
        <div class="hh-extended-filter" data-filter-value="<?= $filterOption ?>">
            <?php if ($filterObj->efp->summary->allCount > 0): ?>
                <?php if ($extfam_obj->config->showPrintButton): ?>
                    <div class="hh-extended-family-actions d-print-none">
                        <a class="btn btn-secondary btn-sm" href="<?= e(route('module', [
                            'module' => $module,
                            'action' => 'Print',
                            'tree'   => $tree_name,
                            'xref'   => $individual->xref(),
                            'filter' => $filterOption,
                        ])) ?>" target="_blank" rel="noopener noreferrer">
                            <i class="fas fa-print" aria-hidden="true"></i>
                            <?= I18N::translate('Print/PDF') ?>
                        </a>
                    </div>
                <?php endif ?>
                <?php if ($extfam_obj->config->useClippingsCart): ?>
                    <?= view($module . '::partials/clippings-cart-button', [
                        'action_mode'  => $clippings_cart_action,
                        'filterOption' => $filterOption,
                        'individual'   => $individual,
                        'module'       => $module,
                        'tree_name'    => $tree_name,
                    ]) ?>
                <?php endif ?>
                <?php foreach ($filterObj->efp as $propName => $propValue) : ?>
                    <?php if ($propName !== 'summary'): ?>
                        <?php if (($filterObj->efp->$propName->allCount > 0) or ($extfam_obj->config->showEmptyBlock == 0)): ?>
                            <?= view($module . '::partials/family-part-header', [
                                'extfam_obj' => $extfam_obj,
                                'filterObj'  => $filterObj,
                                'propName'   => $propName,
                            ]) ?>
                        <?php endif ?>
                        <?php if ($filterObj->efp->$propName->allCount): ?>
                            <?= view($module . '::partials/family-part-summary', [
                                'extfam_obj'   => $extfam_obj,
                                'filterObj'    => $filterObj,
                                'filterOption' => $filterOption,
                                'propName'     => $propName,
                                'summaryName'  => $summaryName,
                            ]) ?>
                            <?= view($module . '::partials/family-part-members', [
                                'extfam_obj'  => $extfam_obj,
                                'filterObj'   => $filterObj,
                                'individual'  => $individual,
                                'module'      => $module,
                                'propName'    => $propName,
                            ]) ?>
                        <?php else: ?>
                            <?php if ($extfam_obj->config->showEmptyBlock == 0): ?>
                                <?= view($module . '::partials/empty-family-part', [
                                    'propName'    => $propName,
                                    'summaryName' => $summaryName,
                                ]) ?>
                            <?php endif ?>
                        <?php endif ?>
                    <?php endif ?>
                <?php endforeach ?>
                <?php if ($extfam_obj->config->showSummary == 1) : ?>
                    <?= view($module . '::partials/summary', [
                        'extfam_obj' => $extfam_obj,
                        'filterObj'  => $filterObj,
                    ]) ?>
                <?php endif ?>
            <?php else: ?>
                <h3><?= I18N::translate('No family available') ?></h3>
            <?php endif ?>
        </div>
    <?php endforeach ?>
</div>

<?= view($module . '::partials/filter-script', [
    'extended_family_css' => $extended_family_css,
]) ?>
