<script>
  $('.wt-table-menu td.move').click(function () {
      var row = $(this).closest('tr');

      if ($(this).hasClass('up')) {
          row.prev().before(row);
      } else {
          row.next().after(row);
      }

      return false;
  });

  $('.hh-extended-family-select-all').click(function () {
      $('.hh-extended-family-part-status').prop('checked', true);
  });

  $('.hh-extended-family-select-none').click(function () {
      $('.hh-extended-family-part-status').prop('checked', false);
  });

  $('.hh-extended-family-select-in-law').click(function () {
      $('.hh-extended-family-part-status[data-in-law="1"]').prop('checked', true);
  });

  $('.hh-extended-family-deselect-in-law').click(function () {
      $('.hh-extended-family-part-status[data-in-law="1"]').prop('checked', false);
  });

  $('.hh-extended-family-apply-degree').click(function () {
      const degreeLimit = parseInt($('.hh-extended-family-degree-limit').val(), 10);

      if (Number.isNaN(degreeLimit)) {
          $('.hh-extended-family-part-status').prop('checked', true);
          return;
      }

      $('.hh-extended-family-part-status').each(function () {
          const degree = parseInt($(this).data('degree'), 10);

          if (!Number.isNaN(degree)) {
              $(this).prop('checked', degree <= degreeLimit);
          }
      });
  });

  function updateDependencyWarnings() {
      const summaryDisabled = $('input[name="show_summary"]:checked').val() === '1';
      const statisticsEnabled = $('input[name="show_summary_statistics"]:checked').val() === '0';
      const emptyPartsCollectedAtSummary = $('[name="show_empty_block"]').val() === '1';
      const relationshipMouseoverEnabled = $('input[name="show_relationship_to_proband"]:checked').val() === '0';
      const relationshipNamesAvailable = <?= $relationship_names_available ? 'true' : 'false' ?>;

      $('.hh-extended-family-summary-statistics-warning').toggleClass('d-none', !(summaryDisabled && statisticsEnabled));
      $('.hh-extended-family-empty-summary-warning').toggleClass('d-none', !(summaryDisabled && emptyPartsCollectedAtSummary));
      $('.hh-extended-family-relationship-warning').toggleClass('d-none', !(!relationshipNamesAvailable && relationshipMouseoverEnabled));
  }

  $('input[name="show_summary"], input[name="show_summary_statistics"], input[name="show_relationship_to_proband"], [name="show_empty_block"]').on('change', updateDependencyWarnings);
  updateDependencyWarnings();
</script>
