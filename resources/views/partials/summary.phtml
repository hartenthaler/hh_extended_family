<?php

use Fisharebest\Webtrees\I18N;
use Hartenthaler\Webtrees\Module\ExtendedFamily\ExtendedFamilySupport;

/**
 * @var object $extfam_obj contains all the information which has to be shown
 * @var object $filterObj  contains the filtered extended family data
 */

$partnerChainsCount = $filterObj->efp->partner_chains->allCount ?? 0;
$showPartnerChainsNotCounted = !$extfam_obj->config->countPartnerChainsToTotal && $partnerChainsCount > 1;
$emptyFamilyParts = array_map(
    static fn (string $familyPart): string => ExtendedFamilySupport::translateFamilyPart($familyPart),
    $filterObj->efp->summary->summaryMessageEmptyBlocks
);
$statistics = $filterObj->efp->summary->statistics ?? null;
?>

<div id="hh-extended-family-summary-block">
    <h2><?= I18N::translate('Summary for the shown extended family') ?></h2>
    <p><?= rtrim(I18N::plural('The extended family has only %1$s as a member.', 'The extended family of %1$s has %2$d members (including %3$s).', $filterObj->efp->summary->allCountUnique, $extfam_obj->proband->niceName->forFamilyOf, $filterObj->efp->summary->allCountUnique, $extfam_obj->proband->niceName->name), '.') ?><?php if ($showPartnerChainsNotCounted) : ?> <?= I18N::translate('(additional members of the partner chains are not counted)') ?><?php endif ?>.
        <?php if ($filterObj->efp->summary->allCountUnique - 1 < $filterObj->efp->summary->allCount - ($extfam_obj->config->countPartnerChainsToTotal?0:(false?$filterObj->efp->partner_chains->allCount:0))) : ?>
            <?= I18N::translate('Some of them are member in more than one part of the extended family.') ?>
        <?php endif ?>
    </p>
    <?php if ($extfam_obj->config->showSummaryStatistics && $statistics !== null) : ?>
        <?php if ($statistics->living->show) : ?>
            <p><?= I18N::translate('Living members: %1$s (%2$s); deceased members: %3$s (%4$s).', I18N::number($statistics->living->livingCount), I18N::percentage($statistics->living->livingPercent), I18N::number($statistics->living->deceasedCount), I18N::percentage($statistics->living->deceasedPercent)) ?></p>
        <?php endif ?>
        <?php if ($statistics->sex->show) : ?>
            <?php if ($statistics->sex->otherSexCount > 0) : ?>
                <p><?= I18N::translate('Gender distribution: %1$s male (%2$s), %3$s female (%4$s), %5$s other or unknown (%6$s).', I18N::number($statistics->sex->maleCount), I18N::percentage($statistics->sex->malePercent), I18N::number($statistics->sex->femaleCount), I18N::percentage($statistics->sex->femalePercent), I18N::number($statistics->sex->otherSexCount), I18N::percentage($statistics->sex->otherSexPercent)) ?></p>
            <?php else : ?>
                <p><?= I18N::translate('Gender distribution: %1$s male (%2$s), %3$s female (%4$s).', I18N::number($statistics->sex->maleCount), I18N::percentage($statistics->sex->malePercent), I18N::number($statistics->sex->femaleCount), I18N::percentage($statistics->sex->femalePercent)) ?></p>
            <?php endif ?>
        <?php endif ?>
        <?php if ($statistics->dateRange->show) : ?>
            <p><?= ExtendedFamilySupport::translateKnownDateRange($statistics->dateRange->startDate, $statistics->dateRange->startDateType, $statistics->dateRange->endDate, $statistics->dateRange->endDateType) ?></p>
        <?php endif ?>
    <?php endif ?>
    <?php if ($extfam_obj->config->showEmptyBlock == 1) : ?>
        <?php if (count($emptyFamilyParts) > 0) : ?>
            <?php if (count($emptyFamilyParts) == 1) : ?>
                <p><?= I18N::translate('%s has no %s recorded.', $extfam_obj->proband->niceName->name, $emptyFamilyParts[0]) ?></p>
            <?php else: ?>
                <?php
                // Keep the final family part separate so the sentence can say
                // "no A, B, and no C recorded".
                $lastEmptyFamilyPart = array_pop($emptyFamilyParts);
                $otherEmptyFamilyParts = implode(', ', $emptyFamilyParts);
                ?>
                <p><?= I18N::translate('%s has no %s, and no %s recorded.', $extfam_obj->proband->niceName->name, $otherEmptyFamilyParts, $lastEmptyFamilyPart) ?></p>
            <?php endif ?>
        <?php endif ?>
    <?php endif ?>
</div>
